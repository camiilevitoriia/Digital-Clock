|circ_contador_assincrono
clk => divisor_frequencia:i0.clkin
clr => contador_assincrono:i1.clr
Q1[0] <= contador_assincrono:i1.Q1[0]
Q1[1] <= contador_assincrono:i1.Q1[1]
Q1[2] <= contador_assincrono:i1.Q1[2]


|circ_contador_assincrono|divisor_frequencia:i0
clkin => novoclok.CLK

clkin => contador[21].CLK
clkin => contador[22].CLK
clkin => contador[23].CLK
clkin => contador[24].CLK
clkout <= novoclok.DB_MAX_OUTPUT_PORT_TYPE


|circ_contador_assincrono|contador_assincrono:i1
clk => fft:i0.clk
clr => fft:i0.clr
clr => fft:i1.clr
clr => fft:i2.clr
Q1[0] <= fft:i0.Q
Q1[1] <= fft:i1.Q
Q1[2] <= fft:i2.Q


|circ_contador_assincrono|contador_assincrono:i1|fft:i0
